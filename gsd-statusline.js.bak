#!/usr/bin/env node
// gsd-hook-version: 1.30.0
// Claude Code Statusline - GSD Edition
// Shows: model | current task | directory | worktree | context usage

const fs = require('fs');
const path = require('path');
const os = require('os');
const { execFileSync } = require('child_process');

// Read JSON from stdin
let input = '';
// Timeout guard: if stdin doesn't close within 3s (e.g. pipe issues on
// Windows/Git Bash), exit silently instead of hanging. See #775.
const stdinTimeout = setTimeout(() => process.exit(0), 3000);
process.stdin.setEncoding('utf8');
process.stdin.on('data', chunk => input += chunk);
process.stdin.on('end', () => {
  clearTimeout(stdinTimeout);
  try {
    const data = JSON.parse(input);
    const model = data.model?.display_name || 'Claude';
    const dir = data.workspace?.current_dir || process.cwd();
    const session = data.session_id || '';
    const remaining = data.context_window?.remaining_percentage;

    // Context window display (shows USED percentage scaled to usable context)
    // Claude Code reserves ~16.5% for autocompact buffer, so usable context
    // is 83.5% of the total window. We normalize to show 100% at that point.
    const AUTO_COMPACT_BUFFER_PCT = 16.5;
    let ctx = '';
    if (remaining != null) {
      // Normalize: subtract buffer from remaining, scale to usable range
      const usableRemaining = Math.max(0, ((remaining - AUTO_COMPACT_BUFFER_PCT) / (100 - AUTO_COMPACT_BUFFER_PCT)) * 100);
      const used = Math.max(0, Math.min(100, Math.round(100 - usableRemaining)));

      // Write context metrics to bridge file for the context-monitor PostToolUse hook.
      // The monitor reads this file to inject agent-facing warnings when context is low.
      if (session) {
        try {
          const bridgePath = path.join(os.tmpdir(), `claude-ctx-${session}.json`);
          const bridgeData = JSON.stringify({
            session_id: session,
            remaining_percentage: remaining,
            used_pct: used,
            timestamp: Math.floor(Date.now() / 1000)
          });
          fs.writeFileSync(bridgePath, bridgeData);
        } catch (e) {
          // Silent fail -- bridge is best-effort, don't break statusline
        }
      }

      // Build progress bar (10 segments)
      const filled = Math.floor(used / 10);
      const bar = '█'.repeat(filled) + '░'.repeat(10 - filled);

      // Color based on usable context thresholds
      if (used < 25) {
        ctx = ` \x1b[36m${bar} ${used}%\x1b[0m`;
      } else if (used < 50) {
        ctx = ` \x1b[32m${bar} ${used}%\x1b[0m`;
      } else if (used < 65) {
        ctx = ` \x1b[33m${bar} ${used}%\x1b[0m`;
      } else if (used < 80) {
        ctx = ` \x1b[38;5;208m${bar} ${used}%\x1b[0m`;
      } else {
        ctx = ` \x1b[5;31m💀 ${bar} ${used}%\x1b[0m`;
      }
    }

    // Current task from todos
    let task = '';
    const homeDir = os.homedir();
    // Respect CLAUDE_CONFIG_DIR for custom config directory setups (#870)
    const claudeDir = process.env.CLAUDE_CONFIG_DIR || path.join(homeDir, '.claude');
    const todosDir = path.join(claudeDir, 'todos');
    if (session && fs.existsSync(todosDir)) {
      try {
        const files = fs.readdirSync(todosDir)
          .filter(f => f.startsWith(session) && f.includes('-agent-') && f.endsWith('.json'))
          .map(f => ({ name: f, mtime: fs.statSync(path.join(todosDir, f)).mtime }))
          .sort((a, b) => b.mtime - a.mtime);

        if (files.length > 0) {
          try {
            const todos = JSON.parse(fs.readFileSync(path.join(todosDir, files[0].name), 'utf8'));
            const inProgress = todos.find(t => t.status === 'in_progress');
            if (inProgress) task = inProgress.activeForm || '';
          } catch (e) {}
        }
      } catch (e) {
        // Silently fail on file system errors - don't break statusline
      }
    }

    // GSD update available?
    let gsdUpdate = '';
    const cacheFile = path.join(claudeDir, 'cache', 'gsd-update-check.json');
    if (fs.existsSync(cacheFile)) {
      try {
        const cache = JSON.parse(fs.readFileSync(cacheFile, 'utf8'));
        if (cache.update_available) {
          gsdUpdate = '\x1b[33m⬆ /gsd:update\x1b[0m │ ';
        }
        if (cache.stale_hooks && cache.stale_hooks.length > 0) {
          gsdUpdate += '\x1b[31m⚠ stale hooks — run /gsd:update\x1b[0m │ ';
        }
      } catch (e) {}
    }

    // Git status: detect dirty working tree and current branch
    let isDirty = false;
    let branch = '';
    let pushStatus = ''; // '' = not a git repo, 'pushed' = all pushed, 'unpushed' = has unpushed commits
    try {
      const gitStatus = execFileSync('git', ['-C', dir, '--no-optional-locks', 'status', '--porcelain'], {
        timeout: 2000,
        stdio: ['ignore', 'pipe', 'ignore']
      }).toString();
      isDirty = gitStatus.trim().length > 0;
    } catch (e) {
      // Not a git repo or git not available — silently ignore
    }
    try {
      branch = execFileSync('git', ['-C', dir, '--no-optional-locks', 'rev-parse', '--abbrev-ref', 'HEAD'], {
        timeout: 2000,
        stdio: ['ignore', 'pipe', 'ignore']
      }).toString().trim();
      // Suppress detached HEAD noise
      if (branch === 'HEAD') branch = '';
    } catch (e) {
      // Not a git repo or git not available — silently ignore
    }
    // Git push status: check for unpushed commits vs remote tracking branch
    if (branch) {
      try {
        const unpushed = execFileSync('git', ['-C', dir, '--no-optional-locks', 'rev-list', '--count', `@{u}..HEAD`], {
          timeout: 2000,
          stdio: ['ignore', 'pipe', 'ignore']
        }).toString().trim();
        pushStatus = parseInt(unpushed, 10) > 0 ? 'unpushed' : 'pushed';
      } catch (e) {
        // No upstream configured — treat as unpushed (local-only branch)
        // Check if HEAD has any commits first (ignore empty repos)
        try {
          execFileSync('git', ['-C', dir, '--no-optional-locks', 'rev-parse', 'HEAD'], {
            timeout: 1000,
            stdio: ['ignore', 'pipe', 'ignore']
          });
          pushStatus = 'unpushed';
        } catch (e2) {
          // Empty repo — no status to show
        }
      }
    }

    // Worktree: detect if worktrees exist and whether we're in one
    let worktreeLabel = '';
    let hasWorktrees = false;
    let inWorktree = false;
    if (data.worktree && data.worktree.name) {
      worktreeLabel = data.worktree.name;
      hasWorktrees = true;
      inWorktree = true;
    } else {
      try {
        const wtList = execFileSync('git', ['-C', dir, '--no-optional-locks', 'worktree', 'list', '--porcelain'], {
          timeout: 2000,
          stdio: ['ignore', 'pipe', 'ignore']
        }).toString();
        // Parse worktree list: find an entry whose path matches `dir`
        const normalizedDir = dir.replace(/\\/g, '/').toLowerCase();
        const blocks = wtList.split(/\n\n+/);
        const allWorktrees = blocks
          .map(block => {
            const lines = block.split('\n');
            const wtPath = (lines.find(l => l.startsWith('worktree ')) || '').replace('worktree ', '').trim();
            const branch = (lines.find(l => l.startsWith('branch ')) || '').replace('branch refs/heads/', '').trim();
            return { path: wtPath.replace(/\\/g, '/').toLowerCase(), branch };
          })
          .filter(wt => wt.path);

        if (allWorktrees.length > 1) {
          hasWorktrees = true;
          const currentWt = allWorktrees.find(wt => normalizedDir.startsWith(wt.path));
          const mainWt = allWorktrees[0];
          if (currentWt && currentWt.path !== mainWt.path) {
            inWorktree = true;
            worktreeLabel = currentWt.branch || path.basename(currentWt.path);
          }
        }
      } catch (e) {
        // Silently ignore
      }
    }

    // Output
    const dirname = path.basename(dir);
    const branchSuffix = branch ? ` (${branch})` : '';
    // Apply red color + asterisk when repo is dirty
    const dirDisplay = isDirty
      ? `\x1b[31m${dirname}*\x1b[0m\x1b[38;5;252m${branchSuffix}\x1b[0m`
      : `\x1b[38;5;252m${dirname}${branchSuffix}\x1b[0m`;

    // Git push status indicator
    // Clean + fully pushed = no indicator (silent success).
    // Unpushed commits OR dirty working tree = warn the user action is needed.
    const needsAction = isDirty || pushStatus === 'unpushed';
    const pushIndicator = needsAction ? ' \x1b[33m⚠ git\x1b[0m' : '';

    // Worktree indicator: ...🌴🌲🌳... when worktrees exist, >🌳< when inside one
    let worktreePart = '';
    if (inWorktree) {
      worktreePart = ` >\x1b[32m🌳\x1b[0m< \x1b[38;5;252m${worktreeLabel}\x1b[0m`;
    } else if (hasWorktrees) {
      worktreePart = ' ...🌴🌲🌳...';
    }

    if (task) {
      process.stdout.write(`${gsdUpdate}\x1b[38;5;252m${model}\x1b[0m │ \x1b[1m${task}\x1b[0m │ ${dirDisplay}${worktreePart}${pushIndicator}${ctx}`);
    } else {
      process.stdout.write(`${gsdUpdate}\x1b[38;5;252m${model}\x1b[0m │ ${dirDisplay}${worktreePart}${pushIndicator}${ctx}`);
    }
  } catch (e) {
    // Silent fail - don't break statusline on parse errors
  }
});
